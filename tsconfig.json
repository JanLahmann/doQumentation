{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    // TS 6.0 deprecated baseUrl (hard error; removed in 7.0). Silence until the
    // Docusaurus tsconfig drops its reliance on it. NOTE: this value is only
    // valid on TS >= 6.0, so it ships together with the typescript@6 bump.
    "ignoreDeprecations": "6.0",
    "paths": {
      "@site/*": ["./*"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "docs/**/*",
    "docusaurus.config.ts",
    "sidebars.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
