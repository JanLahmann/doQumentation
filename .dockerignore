# Exclude most locale notebooks from Binder Docker build context.
# Keeps only EN + 6 major locales (de, es, fr, ja, ko, ro).
# Reduces COPY from ~45K files to ~12K, preventing mybinder.org build timeout.
# Excluded locales remain in git repo — just not in Binder container.
ar/
aut/
bad/
bar/
bln/
cs/
gsw/
he/
id/
it/
ksh/
ms/
nds/
pl/
pt/
sax/
swg/
th/
tl/
uk/
