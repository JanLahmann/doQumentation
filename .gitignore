# Dependencies
node_modules/

# Build output
build/
.docusaurus/
.cache-loader/

# Content sync (generated at runtime)
# docs/ subtrees are tracked in git so per-file history is available for the
# upstream-source-date footer and so PR review can see what each upstream
# sync changes. Notebooks and static caches stay ignored (large binaries).
# Workshop .mdx ARE tracked (they're translated like other docs); only the
# generated workshop images/binaries stay ignored.
notebooks/
docs/workshop/*.png
docs/workshop/_*_imgs/
static/docs/
static/learning/images/

# Stale root-level artifacts from previous Docusaurus locale-build / generate-locale-notebooks
# layouts. Current pipeline writes to build/<locale>/ and static/notebooks/ instead.
# Anchored to repo root so they don't shadow tracked paths like i18n/<loc>/ or docs/tutorials/.
/tutorials/
/guides/
/learning/
/qiskit-addons/
/ar/
/aut/
/bad/
/bar/
/bln/
/cs/
/de/
/es/
/fr/
/gsw/
/he/
/id/
/it/
/ja/
/ko/
/ksh/
/ms/
/nds/
/pl/
/pt/
/ro/
/sax/
/swg/
/th/
/tl/
/uk/

# Generated sidebars + other sync-content.py output, kept out of the repo root.
# sidebars.ts requires them from .generated/ and falls back to empty/autogenerated
# if the dir is absent, so a fresh clone builds before the first sync.
.generated/

# i18n fallback files (generated by populate-locale, genuine translations force-added)
# Ignore the current/ subdirectory (MDX fallbacks) but NOT current.json (sidebar translations)
i18n/*/docusaurus-plugin-content-docs/current/

# Archives
*.tar.gz

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code internal files (per-user state — plans, agent project state,
# scheduled-task locks, code reviews, and local permission/env settings).
# Do not commit settings.json — it contains per-user paths and command allowlists.
.claude/code-review-*.md
.claude/plans/
# …but keep intentional, hand-written planning docs that ship with feature work.
# Auto-generated /plan outputs use random 3-word names (e.g. melodic-munching-salamander.md)
# so they don't match these explicit allowlist entries.
!.claude/plans/simplify-settings.md
!.claude/plans/workshop-mode-codeengine.md
.claude/projects/
.claude/scheduled_tasks.lock
.claude/settings.json
.claude/settings.local.json
# Local-only security reviews and migration drafts — must NOT land in this
# public repo (contain infra/security detail and per-user planning).
.claude/*SECURITY*.md
.claude/BOB_*.md
.claude/ORG_MIGRATION_PLAN.md

# Stale generated docs/images/ from older sync layout. Current pipeline writes
# to static/docs/images/ (already ignored above).
docs/images/

# Python cache
__pycache__/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
translation/manifests/
# Per-locale retranslation workfiles + finalize-failure lists. Kept out of /tmp
# (which the OS reaps mid-run — broke the fr refresh this sync) but never
# committed; regenerated by update-translations.py --generate-workfile.
translation/workfiles/

# notebook-sweep raw run data (regenerated by scripts/notebook-sweep/sweep.py)
.sweep-out/
